# Single-stage: Node agent.
# AXL Linux binary must be pre-built by running:
#   bash infra/build-axl-linux.sh
# before this Dockerfile is used.

FROM node:22-alpine AS agent
WORKDIR /app

# Copy pre-compiled AXL Linux binary (built by infra/build-axl-linux.sh)
COPY infra/bin/axl /usr/local/bin/axl
RUN chmod +x /usr/local/bin/axl

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace files
COPY package.json pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/ ./packages/
COPY examples/maintainer-swarm/ ./examples/maintainer-swarm/

# Install deps
RUN pnpm install --frozen-lockfile

# Build SDK and swarm
RUN pnpm --filter @state-capsule/sdk build
RUN pnpm --filter @state-capsule/maintainer-swarm build

# Entrypoint: start AXL daemon then the agent runtime
COPY infra/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
