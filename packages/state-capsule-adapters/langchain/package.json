{
  "name": "@state-capsule/adapter-langchain",
  "version": "0.1.0",
  "description": "State Capsule adapter for LangChain — BaseMemory subclass + Runnable wrapper",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "peerDependencies": {
    "@state-capsule/sdk":  "workspace:*",
    "@langchain/core":     ">=0.3.0"
  },
  "devDependencies": {
    "@state-capsule/sdk": "workspace:*",
    "@langchain/core":    "^1.1.43",
    "typescript":         "^5.5.0",
    "vitest":             "^2.0.0"
  }
}
