{
  "name": "@ghostxd/state-capsule-adapter-openclaw",
  "version": "0.1.0",
  "description": "State Capsule adapter for OpenClaw: capsule-backed working memory for OpenClaw agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "peerDependencies": {
    "@ghostxd/state-capsule-sdk": "^0.1.0",
    "openclaw": ">=2026.0.0"
  },
  "devDependencies": {
    "@ghostxd/state-capsule-sdk": "workspace:*",
    "openclaw": "^2026.4.29",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
