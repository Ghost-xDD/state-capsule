{
  "name": "@ghostxd/state-capsule-adapter-vercel-ai",
  "version": "0.1.0",
  "description": "State Capsule adapter for Vercel AI SDK — onStepFinish checkpoint middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "peerDependencies": {
    "@ghostxd/state-capsule-sdk": "workspace:*",
    "ai":                 ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true }
  },
  "devDependencies": {
    "@ghostxd/state-capsule-sdk": "workspace:*",
    "typescript":         "^5.5.0",
    "vitest":             "^2.0.0"
  }
}
