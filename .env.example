# ── 0G Network ─────────────────────────────────────────────────────────────
# Private key for the wallet that signs capsule transactions (hex, no 0x prefix)
OG_PRIVATE_KEY=

# EVM RPC for 0G Chain (testnet default)
OG_EVM_RPC=https://evmrpc-testnet.0g.ai

# Indexer RPC for 0G Storage (turbo testnet default)
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G KV client HTTP endpoint
OG_KV_CLIENT_URL=http://3.101.147.150:6789

# 0G Flow contract address (auto-discovered by Indexer, but required by Batcher)
# Get from: https://docs.0g.ai/developer-hub/testnet/testnet-overview
OG_FLOW_CONTRACT=

# ── 0G Compute ──────────────────────────────────────────────────────────────
# Provider address to use for sealed inference (mainnet: GLM-5-FP8 or qwen3.6-plus)
OG_COMPUTE_PROVIDER=

# Provider service URL (from: 0g-compute-cli inference list-providers)
OG_COMPUTE_SERVICE_URL=

# Bearer secret for direct API calls (from: 0g-compute-cli inference get-secret --provider <PROVIDER>)
OG_COMPUTE_SECRET=

# Model name for the chosen provider
OG_COMPUTE_MODEL=GLM-5-FP8

# ── AXL (Gensyn) ────────────────────────────────────────────────────────────
# Path to the AXL binary built from https://github.com/gensyn-ai/axl
AXL_BINARY_PATH=../axl/node

# AXL HTTP API port for this agent (each node uses a different port)
# Triager: 9101 | Reproducer: 9102 | Patcher: 9103 | Reviewer: 9104
AXL_API_PORT=9101

# Comma-separated list of AXL peer bootstrap addresses (tls://host:port)
AXL_BOOTSTRAP_PEERS=

# ── ENS ─────────────────────────────────────────────────────────────────────
# Private key for the wallet that controls the parent ENS name (can share OG_PRIVATE_KEY)
ENS_PRIVATE_KEY=

# RPC for ENS operations (Sepolia recommended for testnet)
ENS_RPC_URL=https://rpc.sepolia.org

# Parent ENS name for task pointers and subnames
ENS_PARENT_NAME=maintainerswarm.eth

# NameStone API key for maintainerswarm.eth (demo swarm — used at runtime)
NAMESTONE_API_KEY=
# NameStone API key for statecapsule.eth (framework parent — parked, not used at runtime)
NAMESTONE_API_KEY_STATECAPSULE=

# ── LLM Providers (for agent intelligence) ──────────────────────────────────
# At least one must be set. Preference order: ANTHROPIC → GROQ → OPENAI
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Demo Mode ───────────────────────────────────────────────────────────────
# live | record | replay
STATE_CAPSULE_MODE=live

# Path to the replay transcript (used in record and replay modes)
STATE_CAPSULE_REPLAY_TRANSCRIPT=./examples/maintainer-swarm/replay/golden.jsonl
